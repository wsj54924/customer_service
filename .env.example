# LLM API Configuration (OpenAI-compatible)
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local embedding)
OLLAMA_BASE_URL=http://localhost:11434

# DashScope (optional, for cloud embedding/reranking)
DASHSCOPE_API_KEY=

# Model selection
CHAT_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o
# EMBEDDING_MODEL is hardcoded to qwen3-embedding:4b
# EMBEDDING_MODEL=qwen3-embedding:4b
RERANKER_MODEL=

# API auth token
KAFU_API_TOKEN=sk_customer_20260518

# Paths
DATA_DIR=./data
VECTOR_STORE_DIR=./data/vector_store
# DashScope embedding model (used when DashScope backend is active)
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
